generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin / operator (agent) hesabı
model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         UserRole       @default(AGENT)
  status       UserStatus     @default(PENDING)
  signature    String?
  avatarUrl    String?
  twoFactorEnabled    Boolean  @default(false)
  twoFactorSecret     String?
  twoFactorBackupCodes String[] @default([])
  resetToken   String?
  resetExpires DateTime?
  emailVerified       Boolean  @default(false)
  emailVerificationToken String?
  emailVerificationExpires DateTime?
  createdAt    DateTime       @default(now())
  sites        Site[]
  siteMemberships SiteMember[]
  assigned     Conversation[] @relation("ConversationAssignee")
  messages     Message[]      @relation("MessageAuthor")
  tickets      Ticket[]       @relation("TicketAssignee")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  AGENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  DELETED
}

// Hər sayt üçün ayrı siteId (widget embed zamanı istifadə olunur)
model Site {
  id            String         @id @default(cuid())
  name          String
  apiKey        String         @unique // public key — widget init üçün
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       SiteMember[]
  quickActions  Json?          // { whatsapp, email, telegram }
  appearance    Json?          // brand color, header, etc.
  settings      Json?          // bot settings: { botActive, agentName, companyDescription, defaultLanguage, supportedLanguages, channels, autoSuggestions }
  createdAt     DateTime       @default(now())
  contacts      Contact[]
  conversations Conversation[]
  tickets       Ticket[]
  subscribers   Subscriber[]
}

// Site team members
model SiteMember {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // MEMBER, ADMIN
  joinedAt  DateTime @default(now())

  @@unique([siteId, userId])
}

// Ziyarətçi (visitor) məlumatları
model Contact {
  id            String         @id @default(cuid())
  siteId        String
  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorToken  String         @unique // widget tərəfindən brauzerdə saxlanılır
  name          String?
  email         String?
  phone         String?
  country       String?        // ISO2 kod (AZ, US, ...)
  countryName   String?        // tam ad (Azerbaijan)
  city          String?
  region        String?
  timezone      String?
  ip            String?
  userAgent     String?
  browser       String?        // Chrome 120
  os            String?        // Windows 11
  device        String?        // Desktop / Mobile
  referrer      String?
  currentUrl    String?
  language      String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  lastSeenAt    DateTime       @default(now())
  conversations Conversation[]
  tickets       Ticket[]
}

// Bir söhbət (conversation) — bir contact ilə bir neçə mesajdan ibarət
model Conversation {
  id         String             @id @default(cuid())
  siteId     String
  site       Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status     ConversationStatus @default(OPEN)
  channel    String             @default("chat") // chat, email, messenger, whatsapp
  assigneeId String?
  assignee   User?              @relation("ConversationAssignee", fields: [assigneeId], references: [id])
  rating          Int?
  ratingComment   String?          @db.Text
  addedToKnowledge Boolean      @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  messages   Message[]

  @@index([siteId, status])
  @@index([contactId])
}

enum ConversationStatus {
  OPEN           // agent baxır
  BOT            // AI / knowledge bot cavab verir
  PENDING_HUMAN  // bot cavab tapa bilmədi, operator lazımdır
  PENDING        // agent gözləyir (köhnə status, uyğunluq üçün)
  SOLVED
}

// Mesaj
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  from           MessageFrom
  text           String       @db.Text
  authorId       String?
  author         User?        @relation("MessageAuthor", fields: [authorId], references: [id])
  attachments    Json?        // [{ name, size, url, type }]
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

enum MessageFrom {
  VISITOR
  AGENT
  BOT
  SYSTEM
}

// Saxlanılan macro cavablar
model Macro {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  text      String   @db.Text
  tag       String?
  createdAt DateTime @default(now())

  @@index([siteId])
}

// Knowledge base məqalələri (FAQ/article/manual entry)
model KnowledgeEntry {
  id        String              @id @default(cuid())
  siteId    String
  title     String
  content   String              @db.Text
  url       String?             // mənbə URL (əgər scrape olunmuşdursa)
  source    KnowledgeSource     @default(MANUAL)
  tags      String[]            @default([])
  status    KnowledgeStatus     @default(ACTIVE)
  // Full-text search üçün generated column (migration-da əlavə olunur)
  // tsvector sütunu manual SQL ilə əlavə olunur
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([siteId, status])
}

enum KnowledgeSource {
  MANUAL
  URL
  IMPORT
}

enum KnowledgeStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Məhsul kataloqu (bot tövsiyə üçün istifadə edə bilər)
model Product {
  id          String         @id @default(cuid())
  siteId      String
  name        String
  description String         @db.Text
  price       Decimal?       @db.Decimal(12, 2)
  currency    String?        @default("AZN")
  imageUrl    String?
  url         String?
  sku         String?
  tags        String[]       @default([])
  source      ProductSource  @default(MANUAL)
  status      ProductStatus  @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([siteId, status])
}

enum ProductSource {
  MANUAL
  URL
  IMPORT
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Ticket sistemi — istifadəçi çat vasitəsilə ticket yarada bilir
model Ticket {
  id             String        @id @default(cuid())
  siteId         String
  site           Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversationId String?
  subject        String
  description    String        @db.Text
  status         TicketStatus  @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  assigneeId     String?
  assignee       User?         @relation("TicketAssignee", fields: [assigneeId], references: [id])
  notes          String?       @db.Text  // admin daxili qeydlər
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([siteId, status])
  @@index([contactId])
}

enum TicketStatus {
  OPEN           // Yeni yaradıldı
  IN_REVIEW      // Komanda nəzərdən keçirir
  IN_PROGRESS    // Üzərində işlənir
  RESOLVED       // Həll olundu
  CANCELLED      // Ləğv olundu
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// E-poçt abunəçiləri (subscribe)
model Subscriber {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  createdAt DateTime @default(now())

  @@unique([siteId, email])
  @@index([siteId])
}
